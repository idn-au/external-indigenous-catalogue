<https://data.idnau.org/pid/organization/61dc125d-7311-4bae-add2-428a68fbfa8f>
    a schema:Organization ;
    dcterms:type <https://data.idnau.org/pid/vocab/org-indigeneity/non-indigenous> ;
    schema:description "The Department of Social Services seeks to improve the lifetime well-being of people and families in Australia through the creation and promotion of longitudinal evidence. The evidence informs policies and practices. The Department produces and manages quality longitudinal datasets, encourages the use of those data assets, fosters collaboration between longitudinal survey developers, researchers and policy makers and facilitates broader use of longitudinal data. " ;
